# Deepgram — transcripción streaming (console.deepgram.com)
DEEPGRAM_API_KEY=

# Google Gemini — generación de respuestas (aistudio.google.com)
GEMINI_API_KEY=

# Opcional: modelo a usar (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Opcional: dominio base para OG images y URLs absolutas
# (default: https://copiloto-mvp.vercel.app)
# NEXT_PUBLIC_SITE_URL=https://tu-dominio.com

# Opcional: lista de espera (Google Form). Si no se setean, usan los defaults
# hardcodeados en app/api/waitlist/route.ts.
# GFORM_ACTION=https://docs.google.com/forms/d/e/XXXX/formResponse
# GFORM_EMAIL_ENTRY=entry.1234567890

# Opcional: kill switch global. Con "1", /api/answer y /api/deepgram-token
# devuelven 503 y la app muestra "cupos agotados + lista de espera".
# La waitlist sigue funcionando. Freno de mano para picos de gasto.
# CAPACITY_CLOSED=1

# Opcional: PostHog para el funnel de eventos (Vercel Hobby descarta los
# eventos custom de Vercel Analytics). Sin la key, la app funciona igual.
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

